{
    "name": "Germsfox",
    "version": "0.2",
    "description": "Custom skins, cell colors, and multibox support for Germs.io",
    "manifest_version": 3,
    "icons": {
        "48": "images/gsDuhFox-48.png",
        "96": "images/gsDuhFox-96.png"
    },
    "action": {
        "default_popup": "src/popup.html",
        "default_icon": {
            "16": "images/gsDuhFox-16.png",
            "48": "images/gsDuhFox-48.png",
            "128": "images/gsDuhFox-128.png"
        }
    },
    "background": {
        "service_worker": "src/background.js",
        "scripts": ["src/background.js"]
    },
    "content_scripts": [
        {
            "matches": ["*://*.germs.io/*"],
            "css": ["src/style.css"],
            "js": [
                "src/dom.js",
                "src/storage.js",
                "src/content.js"
            ]
        }
    ],
    "permissions": [
        "storage",
        "tabs",
        "downloads",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://*.germs.io/*"
    ],
    "web_accessible_resources": [
        {
            "resources": ["fonts/*", "images/*"],
            "matches": ["<all_urls>"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@germsfox-dev",
            "strict_min_version": "58.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
