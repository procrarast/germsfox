{
    "name": "Germsfox",
    "version": "1.1.3",
    "description": "Emotes, skins, themes, gameplay and moderation tools for Germs.io!",
    "manifest_version": 3,
    "icons": {
        "48": "images/gsDuhFox-48.png",
        "96": "images/gsDuhFox-96.png"
    },
    "action": {
        "default_popup": "src/popup.html",
        "default_icon": {
            "16": "images/gsDuhFox-16.png",
            "48": "images/gsDuhFox-48.png",
            "128": "images/gsDuhFox-128.png"
        }
    },
    "background": {
        "service_worker": "src/background.js",
        "scripts": ["src/background.js"]
    },
    "content_scripts": [
        {
            "run_at": "document_idle",
            "matches": ["*://*.germs.io/*"],
            "css": ["src/style.css"],
            "js": [
                "src/dom.js",
                "src/storage.js",
                "src/content.js"
            ]
        }
    ],
    "permissions": [
        "storage",
        "tabs",
        "declarativeNetRequest"
    ],
    "host_permissions": [
        "*://*.germs.io/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "overrides",
                "enabled": true,
                "path": "overrides.json"
            }
        ]
    },
    "web_accessible_resources": [
        {
            "resources": [
                "fonts/*",
                "images/*",
                "/src/overrides/bundle.js",
                "/src/overrides/lib/pixi.js"
            ],
            "matches": ["https://germs.io/*"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@germsfox-dev",
            "strict_min_version": "58.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
